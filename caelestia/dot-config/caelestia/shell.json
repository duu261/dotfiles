{
    "appearance": {
        "font": {
            "body": {
                "family": "FiraCode Nerd Font Propo"
            },
            "clock": "FiraCode Nerd Font Propo",
            "headline": {
                "family": "FiraCode Nerd Font Propo"
            },
            "label": {
                "family": "FiraCode Nerd Font Propo"
            },
            "mono": {
                "family": "FiraCode Nerd Font Mono"
            },
            "title": {
                "family": "FiraCode Nerd Font Propo"
            }
        }
    },
    "background": {
        "desktopClock": {
            "enabled": true
        }
    },
    "bar": {
        "clock": {
            "showDate": true
        },
        "persistent": true,
        "status": {
            "showAudio": false,
            "showBattery": true,
            "showBluetooth": true,
            "showKbLayout": false,
            "showMicrophone": false,
            "showNetwork": true,
            "showWifi": true
        }
    },
    "general": {
        "apps": {
            "terminal": [
                "wezterm"
            ]
        },
        "idle": {
            "inhibitWhenAudio": false,
            "lockBeforeSleep": false,
            "timeouts": [
            ]
        }
    },
    "launcher": {
        "vimKeybinds": true
    },
    "lock": {
        "enableFprint": false
    },
    "notifs": {
        "actionOnClick": true,
        "expire": true
    },
    "services": {
        "audioIncrement": 0.1,
        "brightnessIncrement": 0.1,
        "useFahrenheit": false,
        "useTwelveHourClock": false
    },
    "session": {
        "vimKeybinds": true
    }
}
